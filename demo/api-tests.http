@baseUrl = http://localhost:8080
@clienteId = 1
@consultoriaId = 1
@usuarioId = 1
@solicitudId = 1
@token = PEGA_AQUI_EL_TOKEN

### Login administrador
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@demo.com",
  "password": "admin123"
}

### Login cliente
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "cliente@demo.com",
  "password": "cliente123"
}

### Listar roles
GET {{baseUrl}}/roles
Authorization: Bearer {{token}}

### Listar usuarios
GET {{baseUrl}}/usuarios
Authorization: Bearer {{token}}

### Crear usuario
POST {{baseUrl}}/usuarios
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Cliente API",
  "email": "cliente.api@demo.com",
  "password": "cliente123",
  "rolId": 2
}

### Obtener usuario por id
GET {{baseUrl}}/usuarios/{{usuarioId}}
Authorization: Bearer {{token}}

### Actualizar usuario
PUT {{baseUrl}}/usuarios/{{usuarioId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Cliente API Actualizado",
  "email": "cliente.api.actualizado@demo.com",
  "password": "cliente123",
  "rolId": 2
}

### Eliminar usuario
DELETE {{baseUrl}}/usuarios/{{usuarioId}}
Authorization: Bearer {{token}}

### Listar clientes
GET {{baseUrl}}/clientes
Authorization: Bearer {{token}}

### Crear cliente
POST {{baseUrl}}/clientes
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Empresa Cliente",
  "telefono": "8888-8888",
  "empresa": "Empresa Demo",
  "correo": "contacto@empresademo.com"
}

### Obtener cliente por id
GET {{baseUrl}}/clientes/{{clienteId}}
Authorization: Bearer {{token}}

### Actualizar cliente
PUT {{baseUrl}}/clientes/{{clienteId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Empresa Cliente Actualizada",
  "telefono": "8999-9999",
  "empresa": "Empresa Demo Actualizada",
  "correo": "contacto.actualizado@empresademo.com"
}

### Eliminar cliente
DELETE {{baseUrl}}/clientes/{{clienteId}}
Authorization: Bearer {{token}}

### Listar consultorias
GET {{baseUrl}}/consultorias
Authorization: Bearer {{token}}

### Crear consultoria
POST {{baseUrl}}/consultorias
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "tipo": "Legal corporativa",
  "descripcion": "Revision de contrato comercial."
}

### Obtener consultoria por id
GET {{baseUrl}}/consultorias/{{consultoriaId}}
Authorization: Bearer {{token}}

### Actualizar consultoria
PUT {{baseUrl}}/consultorias/{{consultoriaId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "tipo": "Legal corporativa",
  "descripcion": "Revision de contrato comercial en proceso."
}

### Eliminar consultoria
DELETE {{baseUrl}}/consultorias/{{consultoriaId}}
Authorization: Bearer {{token}}

### Listar solicitudes
GET {{baseUrl}}/solicitudes
Authorization: Bearer {{token}}

### Crear solicitud
POST {{baseUrl}}/solicitudes
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombreSolicitante": "Cliente Demo",
  "correoSolicitante": "cliente@demo.com",
  "descripcion": "Solicito seguimiento de la consultoria.",
  "estado": "PENDIENTE",
  "fecha": "2026-04-28",
  "clienteId": 1,
  "consultoriaId": 1
}

### Obtener solicitud por id
GET {{baseUrl}}/solicitudes/{{solicitudId}}
Authorization: Bearer {{token}}

### Actualizar solicitud
PUT {{baseUrl}}/solicitudes/{{solicitudId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombreSolicitante": "Cliente Demo",
  "correoSolicitante": "cliente@demo.com",
  "descripcion": "Solicito seguimiento actualizado de la consultoria.",
  "estado": "EN_PROCESO",
  "fecha": "2026-04-28",
  "clienteId": 1,
  "consultoriaId": 1
}

### Eliminar solicitud
DELETE {{baseUrl}}/solicitudes/{{solicitudId}}
Authorization: Bearer {{token}}
